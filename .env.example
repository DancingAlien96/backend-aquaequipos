# Puerto del servidor
PORT=4000

# URL de WooCommerce
WOOCOMMERCE_URL=https://tu-tienda.com

# Credenciales de WooCommerce API
# Obtener desde: WooCommerce > Settings > Advanced > REST API
WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# Configuración de CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Ambiente
NODE_ENV=development

# TiloPay API (opcional - solo si usas TiloPay)
TILOPAY_API_URL=https://app.tilopay.com/api/v1
TILOPAY_API_USER=your_tilopay_user
TILOPAY_API_PASSWORD=your_tilopay_password
TILOPAY_API_KEY=your_tilopay_api_key
